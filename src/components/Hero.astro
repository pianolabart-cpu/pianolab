---
import Button from "./Button.astro";
import ArrowRight from "./icons/Arrow-right.astro";

// Hero.astro — PianoLab
---

<!-- Google Fonts: Playfair Display + DM Sans -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@400;500&display=swap"
  rel="stylesheet"
/>

<style>
  .hero-section {
    font-family: "DM Sans", sans-serif;
  }

  /* Entrada suave para todo el hero */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim-1 {
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.05s;
  }
  .anim-2 {
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.2s;
  }
  .anim-3 {
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.35s;
  }
  .anim-4 {
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.5s;
  }
  .anim-5 {
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.65s;
  }

  /* Imagen lateral — entra con fade + slide horizontal */
  @keyframes fadeLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes fadeRight {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .anim-left {
    animation: fadeLeft 0.8s ease both;
    animation-delay: 0.75s;
  }
  .anim-right {
    animation: fadeRight 0.8s ease both;
    animation-delay: 0.75s;
  }
  .anim-center {
    animation: fadeUp 0.8s ease both;
    animation-delay: 0.6s;
  }

  /* Badge pill */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fef3c7;
    color: #92400e;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid #fde68a;
  }

  /* CTA principal */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-brand, #1a1a1a);
    color: #fff;
    font-family: "DM Sans", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 14px 28px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.15s,
      box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  }
  .cta-primary:hover {
    background: var(--color-brand-strong, #000);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
  }

  /* CTA secundario */
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #555;
    font-family: "DM Sans", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 14px 20px;
    border-radius: 12px;
    border: 1.5px solid #e5e7eb;
    background: transparent;
    cursor: pointer;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s,
      background 0.2s;
  }
  .cta-secondary:hover {
    border-color: #d1d5db;
    color: #111;
    background: #f9fafb;
  }

  /* Imágenes laterales con sombra profunda */
  .side-img {
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.18),
      0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .center-img {
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.22),
      0 8px 24px rgba(0, 0, 0, 0.12);
  }

  /* Línea decorativa en el headline */
  .headline-accent {
    position: relative;
    display: inline;
  }
  .headline-accent::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 3px;
    background: var(--color-brand, #1a1a1a);
    border-radius: 2px;
    opacity: 0.25;
  }

  /* Social proof avatars */
  .avatar-stack {
    display: flex;
  }
  .avatar-stack img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    margin-left: -10px;
    object-fit: cover;
    background: #e5e7eb;
  }
  .avatar-stack img:first-child {
    margin-left: 0;
  }
</style>

<section class="hero-section mt-20 w-full overflow-hidden bg-white py-16 md:py-24" id="hero">
  <div
    class="mx-auto flex w-full flex-col items-center justify-center gap-6 px-4 text-center sm:max-w-screen-lg sm:px-8 md:gap-7"
  >
    <!-- Headline -->
    <h1 class="anim-2 max-w-3xl text-5xl leading-[1.1] font-semibold tracking-tight text-gray-950">
      Convierte tu sueño de tocar el piano en
      <em class="headline-accent text-brand not-italic">realidad</em>
    </h1>

    <!-- Subheadline -->
    <p class="anim-3 max-w-xl text-lg leading-relaxed text-gray-500 md:text-xl">
      PianoLab es un programa guiado y acompañado que te ayuda a aprender piano de forma rápida, práctica y con
      <strong class="font-medium text-gray-700">resultados reales</strong> en poco tiempo.
    </p>

    <!-- CTAs -->
    <div class="anim-4 flex flex-col items-center gap-3 sm:flex-row">
      <Button
        title="Agendar una llamada"
        url="https://calendly.com/sanchezamdany/30min?month=2026-04"
        target="_blank"
        size="lg"
      >
        <ArrowRight size={16} />
      </Button>
      <Button title="Ver cómo funciona" url="#programa" target="_blank" size="lg" variant="white">
        <ArrowRight size={16} />
      </Button>
    </div>

    <!-- Social proof -->
    <div class="anim-4 flex items-center gap-3">
      <div class="avatar-stack">
        <img src="https://api.dicebear.com/9.x/notionists/svg?seed=Sofia" alt="Alumno 1" />
        <img src="https://api.dicebear.com/9.x/notionists/svg?seed=Carlos" alt="Alumno 2" />
        <img src="https://api.dicebear.com/9.x/notionists/svg?seed=Lucia" alt="Alumno 3" />
        <img src="https://api.dicebear.com/9.x/notionists/svg?seed=Miguel" alt="Alumno 4" />
      </div>
      <p class="text-sm text-gray-500">
        <span class="font-semibold text-gray-800">+50 alumnos</span> ya aprenden con PianoLab
      </p>
    </div>

    <!-- Imágenes -->
    <div class="anim-5 relative mt-4 flex w-full items-center justify-center md:mt-6">
      <!-- Imagen izquierda -->
      <div
        class="side-img anim-left absolute left-0 hidden w-60 overflow-hidden rounded-2xl lg:block xl:w-72"
        style="transform: rotate(-2deg);"
      >
        <img src="left.jpeg" alt="Piano clase" class="h-60 w-full object-cover xl:h-96" />
        <!-- Overlay sutil -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
      </div>

      <!-- Imagen central -->
      <div class="center-img anim-center z-10 w-110 max-w-2xl overflow-hidden rounded-2xl">
        <img src="hero.jpeg" alt="Tocando el piano" class="w-full object-cover" />
        <!-- Overlay inferior suave -->
        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/10 to-transparent"
        >
        </div>
      </div>

      <!-- Imagen derecha -->
      <div
        class="side-img anim-right absolute right-0 hidden w-60 overflow-hidden rounded-2xl lg:block xl:w-72"
        style="transform: rotate(2deg);"
      >
        <img src="right.jpeg" alt="Notas musicales" class="h-60 w-full object-cover xl:h-96" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
      </div>
    </div>
  </div>
</section>
