---
import Button from "./Button.astro";
import ArrowRight from "./icons/Arrow-right.astro";

const testimonials = [
  {
    name: "Sofía Ramírez",
    age: 28,
    avatar: "https://api.dicebear.com/9.x/notionists/svg?seed=Sofia",
    quote:
      "Nunca pensé que aprendería a tocar una canción completa en tan poco tiempo. En 6 semanas ya tocaba mi primera pieza. PianoLab cambió mi perspectiva totalmente.",
    result: "Primera canción en 6 semanas",
  },
  {
    name: "Carlos Mendoza",
    age: 35,
    avatar: "https://api.dicebear.com/9.x/notionists/svg?seed=Carlos",
    quote:
      "Había intentado aprender piano dos veces antes con apps y tutoriales de YouTube. Nada funcionó hasta que empecé con PianoLab. El acompañamiento personalizado hace toda la diferencia.",
    result: "Después de 2 intentos fallidos",
  },
  {
    name: "Valentina Torres",
    age: 22,
    avatar: "https://api.dicebear.com/9.x/notionists/svg?seed=Valentina",
    quote:
      "Lo mejor es que el programa se adapta a mi ritmo. Soy estudiante y tengo poco tiempo, pero con 20 minutos al día he avanzado más que muchos en meses.",
    result: "Solo 20 min al día",
  },
  {
    name: "Andrés Castillo",
    age: 41,
    avatar: "https://api.dicebear.com/9.x/notionists/svg?seed=Andres",
    quote:
      "A mis 41 años creía que era demasiado tarde para aprender. PianoLab me demostró que no. Hoy toco para mis hijos y es el mejor regalo que me he dado.",
    result: "Nunca es tarde para empezar",
  },
  {
    name: "Lucía Fernández",
    age: 31,
    avatar: "https://api.dicebear.com/9.x/notionists/svg?seed=Lucia",
    quote:
      "El nivel de atención y feedback que recibes es increíble. Sientes que tienes un maestro dedicado solo a ti. Recomiendo PianoLab al 100%.",
    result: "Atención totalmente personalizada",
  },
  {
    name: "Miguel Ángel Ruiz",
    age: 26,
    avatar: "https://api.dicebear.com/9.x/notionists/svg?seed=Miguel",
    quote:
      "Empecé sin saber nada de música. Ahora entiendo teoría, leo partituras básicas y lo más importante, disfruto cada sesión. El método es realmente efectivo.",
    result: "De cero a leer partituras",
  },
];
---

<section class="w-full scroll-m-12 bg-white py-12 md:py-20" id="testimonials">
  <div class="mx-auto flex w-full flex-col items-center gap-12 px-4 sm:max-w-screen-lg sm:px-8">
    <!-- Header -->
    <div data-animate class="flex max-w-2xl flex-col gap-3 text-left md:text-center">
      <p class="text-brand text-sm font-semibold tracking-widest uppercase">Lo que dicen nuestros alumnos</p>
      <h2 class="text-3xl font-semibold text-gray-900 md:text-4xl">Historias reales de personas como tú</h2>
      <p class="text-lg text-gray-500">
        Cientos de personas ya están tocando el piano gracias a PianoLab. Aquí algunos de ellos.
      </p>
    </div>

    <!-- Grid de testimonials -->
    <div class="grid w-full grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((t, i) => (
          <article
            data-animate
            style={`--delay: ${i * 80}ms`}
            class="flex flex-col gap-4 rounded-2xl border border-gray-100 bg-gray-50 p-6 transition-shadow duration-300 hover:shadow-md"
          >
            {/* Estrellas */}
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map(() => (
                <svg
                  class="h-4 w-4 fill-yellow-400 text-yellow-400"
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            {/* Quote */}
            <p class="flex-1 text-sm leading-relaxed text-gray-700"> "{t.quote}"</p>

            {/* Result badge */}
            <div class="inline-flex">
              <span class="bg-brand/10 text-brand rounded-full px-3 py-1 text-xs font-medium">✓ {t.result}</span>
            </div>

            {/* Author */}
            <div class="flex items-center gap-3 border-t border-gray-200 pt-2">
              <img src={t.avatar} alt={t.name} class="h-10 w-10 rounded-full bg-gray-200 object-cover" />
              <div>
                <p class="text-sm font-semibold text-gray-900">{t.name}</p>
                <p class="text-xs text-gray-400">{t.age} años</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- CTA -->
    <Button
      title="Quiero ser el próximo"
      url="https://calendly.com/sanchezamdany/30min?month=2026-04"
      data-animate
      target="_blank"
    >
      <ArrowRight size={16} />
    </Button>
  </div>
</section>
