---
// Button.astro — PianoLab
interface Props {
  title: string;
  url: string;
  target?: "_blank" | "_self";
  variant?: "default" | "white";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { title, url, target = "_self", variant = "default", size = "md", class: className = "" } = Astro.props;

const isExternal = target === "_blank";
const isWhite = variant === "white";

const sizeClasses = {
  sm: "text-xs px-5 py-2",
  md: "text-sm px-6 py-2.5",
  lg: "text-base px-8 py-4",
}[size];
---

<a
  href={url}
  target={target}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class:list={[
    "group focus:ring-brand-medium relative inline-flex cursor-pointer items-center justify-center overflow-hidden rounded-xl leading-5 font-semibold shadow-sm transition-all duration-300 hover:shadow-md focus:ring-4 focus:outline-none",
    sizeClasses,
    isWhite ? "text-brand bg-white hover:bg-white/90" : "bg-brand hover:bg-brand-warm text-white",
    className,
  ]}
>
  {/* Burbujas dentro del botón */}
  <span aria-hidden="true" class="pointer-events-none absolute inset-0">
    {
      isWhite ? (
        <>
          <span class="bg-brand-accent/30 absolute top-1.5 left-4 h-3 w-3 rounded-full transition-transform duration-500 group-hover:-translate-y-1" />
          <span class="bg-brand-warm/40 absolute top-5 left-10 h-1.5 w-1.5 rounded-full transition-transform duration-500 group-hover:-translate-y-1.5" />
          <span class="bg-brand/30 absolute top-2 left-16 h-1 w-1 rounded-full transition-transform duration-500 group-hover:-translate-y-2" />
          <span class="bg-brand/25 absolute right-20 bottom-2 h-2 w-2 rounded-full transition-transform duration-500 group-hover:-translate-y-1" />
          <span class="bg-brand-warm/35 absolute top-3 right-8 h-1.5 w-1.5 rounded-full transition-transform duration-500 group-hover:-translate-y-1.5" />
          <span class="bg-brand-accent/30 absolute right-4 bottom-3 h-1 w-1 rounded-full transition-transform duration-500 group-hover:-translate-y-2" />
        </>
      ) : (
        <>
          <span class="absolute top-1.5 left-4 h-3 w-3 rounded-full bg-white/30 transition-transform duration-500 group-hover:-translate-y-1" />
          <span class="absolute top-5 left-10 h-1.5 w-1.5 rounded-full bg-white/40 transition-transform duration-500 group-hover:-translate-y-1.5" />
          <span class="absolute top-2 left-16 h-1 w-1 rounded-full bg-white/30 transition-transform duration-500 group-hover:-translate-y-2" />
          <span class="absolute right-20 bottom-2 h-2 w-2 rounded-full bg-white/25 transition-transform duration-500 group-hover:-translate-y-1" />
          <span class="absolute top-3 right-8 h-1.5 w-1.5 rounded-full bg-white/35 transition-transform duration-500 group-hover:-translate-y-1.5" />
          <span class="absolute right-4 bottom-3 h-1 w-1 rounded-full bg-white/30 transition-transform duration-500 group-hover:-translate-y-2" />
        </>
      )
    }
  </span>
  <span class="relative inline-flex items-center gap-2">
    {title}
    <slot />
  </span>
</a>
