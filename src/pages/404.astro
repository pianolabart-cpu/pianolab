      {/* CTAs */}
      <div data-animate style="--delay: 160ms" class="flex flex-col items-center gap-3">
        <p class="text-sm text-gray-400">O simplemente vuelve al inicio</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <Button title="Volver al inicio" url="/">
