---
// src/pages/404.astro — PianoLab
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import ArrowRight from "../components/icons/Arrow-right.astro";
---

<Layout title="404 — Página no encontrada · PianoLab" description="Esta página no existe." noindex={true} hideJsonLd={true}>
  <!-- <Navbar /> -->

  <section class="flex min-h-screen w-full items-center justify-center bg-white pt-20">
    <div class="mx-auto flex w-full flex-col items-center gap-12 px-4 py-20 text-center sm:max-w-screen-lg sm:px-8">
      <!-- Header + 404 + teclado -->
      <div data-animate class="flex max-w-2xl flex-col items-center gap-6">
        <p class="text-brand text-sm font-semibold tracking-widest uppercase">Error 404</p>

        {/* 404 gigante con el "0" en gradiente de marca */}
        <div class="flex items-baseline justify-center gap-1 md:gap-2">
          <span class="text-7xl font-bold tracking-tighter text-gray-900 md:text-[10rem]">4</span>
          <span
            class="from-brand via-brand-accent to-brand-warm bg-gradient-to-br bg-clip-text text-7xl font-bold tracking-tighter text-transparent md:text-[10rem]"
            >0</span
          >
          <span class="text-7xl font-bold tracking-tighter text-gray-900 md:text-[10rem]">4</span>
        </div>

        {/* Mini teclado de piano (CSS) */}
        <div class="relative mx-auto w-full max-w-md pt-4">
          <div class="flex h-24 w-full overflow-hidden rounded-xl border border-gray-200 bg-white shadow-lg">
            {Array.from({ length: 12 }).map(() => <div class="flex-1 border-r border-gray-100 last:border-r-0" />)}
          </div>
          <div class="pointer-events-none absolute inset-x-0 top-4 flex h-16">
            {
              [6, 13, 27, 34, 40, 54, 61, 75, 82, 88].map((left) => (
                <div class="absolute h-16 w-[5%] rounded-b-md bg-gray-900" style={`left: ${left}%`} />
              ))
            }
          </div>
        </div>

        <h1 class="text-4xl font-semibold text-gray-900">Esta página se perdió entre las teclas</h1>
        <p class="text-lg text-gray-500">
          La página que buscas no existe o fue movida. Vuelve al inicio y sigue tu camino hacia el piano.
        </p>
      </div>

      {/* Links en 3 columnas */}
